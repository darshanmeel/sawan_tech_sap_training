{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": [
        "https://darshanmeel.github.io/sawan_tech_sap_training/",
        "https://darshanmeel.github.io/sawan_tech_sap_training/tables/",
        "https://darshanmeel.github.io/sawan_tech_sap_training/glossary/",
        "https://darshanmeel.github.io/sawan_tech_sap_training/articles/",
        "https://darshanmeel.github.io/sawan_tech_sap_training/walkthrough/beginner/vbak/",
        "https://darshanmeel.github.io/sawan_tech_sap_training/walkthrough/intermediate/acdoca/",
        "https://darshanmeel.github.io/sawan_tech_sap_training/walkthrough/expert/acdoca/"
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.90 }],
        "categories:seo": ["warn", { "minScore": 0.95 }]
      }
    }
  }
}
